# Copy to config/release/release.env and replace placeholder values for real releases.

FLOUI_RELEASE_VERSION=0.1.0
FLOUI_BUILD_NUMBER=100
FLOUI_BUNDLE_ID=com.floui.app
FLOUI_APP_NAME=Floui
FLOUI_EXECUTABLE_NAME=FlouiApp
FLOUI_MINIMUM_SYSTEM_VERSION=15.0

# Signing and notarization.
FLOUI_TEAM_ID=ABCDE12345
FLOUI_CODESIGN_IDENTITY="Developer ID Application: Example Corp (ABCDE12345)"
FLOUI_NOTARY_PROFILE=floui-notary

# Sparkle-compatible update metadata.
FLOUI_APPCAST_URL=https://downloads.example.com/floui/appcast.xml
FLOUI_SUPUBLIC_ED_KEY=BASE64_ED25519_PUBLIC_KEY
FLOUI_RELEASE_NOTES_URL=https://downloads.example.com/floui/releases/
FLOUI_UPDATE_CHANNEL=stable
FLOUI_SU_ENABLE_AUTOMATIC_CHECKS=YES
FLOUI_SU_AUTOMATICALLY_UPDATE=YES
FLOUI_SU_ALLOWS_AUTOMATIC_UPDATES=YES
FLOUI_SU_VERIFY_UPDATE_BEFORE_EXTRACTION=YES
FLOUI_SU_REQUIRE_SIGNED_FEED=YES
FLOUI_SU_SCHEDULED_CHECK_INTERVAL=86400
FLOUI_SU_IMPATIENT_CHECK_INTERVAL=604800

# App bundle metadata.
FLOUI_APPLE_EVENTS_USAGE_DESCRIPTION="Floui needs Automation access to arrange browser windows and developer tools for your workspaces."
FLOUI_COPYRIGHT="Copyright 2026 Floui"
