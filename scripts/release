#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/release-common.sh"

CONFIG_FILE="$ROOT_DIR/config/release/release.env"
OUTPUT_DIR=""
WITH_DMG=0
SKIP_SIGN=0
SKIP_NOTARIZE=0
SKIP_APPCAST=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)
      CONFIG_FILE="$2"
      shift 2
      ;;
    --output)
      OUTPUT_DIR="$2"
      shift 2
      ;;
    --with-dmg)
      WITH_DMG=1
      shift
      ;;
    --skip-sign)
      SKIP_SIGN=1
      shift
      ;;
    --skip-notarize)
      SKIP_NOTARIZE=1
      shift
      ;;
    --skip-appcast)
      SKIP_APPCAST=1
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

build_args=(--config "$CONFIG_FILE")
if [[ -n "$OUTPUT_DIR" ]]; then
  build_args+=(--output "$OUTPUT_DIR")
fi
"$SCRIPT_DIR/build-release-bundle" "${build_args[@]}"

load_release_env "$CONFIG_FILE"
app_output_dir="$(resolve_release_output_dir "$OUTPUT_DIR")"
APP_PATH="$(release_app_path "$app_output_dir")"
ZIP_PATH="$(release_zip_path "$app_output_dir")"

if [[ "$SKIP_SIGN" != "1" ]]; then
  "$SCRIPT_DIR/sign-release-bundle" --config "$CONFIG_FILE" --app "$APP_PATH"
fi

package_args=(--config "$CONFIG_FILE" --app "$APP_PATH")
if [[ "$WITH_DMG" == "1" ]]; then
  package_args+=(--with-dmg)
fi
"$SCRIPT_DIR/package-release" "${package_args[@]}"

if [[ "$SKIP_NOTARIZE" != "1" ]]; then
  "$SCRIPT_DIR/notarize-release" --config "$CONFIG_FILE" --app "$APP_PATH" --archive "$ZIP_PATH"
fi

if [[ "$SKIP_APPCAST" != "1" ]]; then
  "$SCRIPT_DIR/generate-appcast" --config "$CONFIG_FILE" --artifacts "$app_output_dir"
fi
