#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/release-common.sh"

CONFIG_FILE="$ROOT_DIR/config/release/release.env"
ARTIFACTS_DIR=""
GENERATE_APPCAST_BIN="${FLOUI_GENERATE_APPCAST_BIN:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)
      CONFIG_FILE="$2"
      shift 2
      ;;
    --artifacts)
      ARTIFACTS_DIR="$2"
      shift 2
      ;;
    --bin)
      GENERATE_APPCAST_BIN="$2"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

load_release_env "$CONFIG_FILE"

if [[ -z "$ARTIFACTS_DIR" ]]; then
  ARTIFACTS_DIR="$(default_release_output_dir)"
fi

if [[ -z "$GENERATE_APPCAST_BIN" ]]; then
  GENERATE_APPCAST_BIN="$(command -v generate_appcast || true)"
fi

if [[ -z "$GENERATE_APPCAST_BIN" ]]; then
  echo "Unable to locate generate_appcast. Install Sparkle's tool or set FLOUI_GENERATE_APPCAST_BIN." >&2
  exit 1
fi

if [[ ! -d "$ARTIFACTS_DIR" ]]; then
  echo "Artifacts directory not found: $ARTIFACTS_DIR" >&2
  exit 1
fi

"$GENERATE_APPCAST_BIN" "$ARTIFACTS_DIR"
echo "Generated appcast in $ARTIFACTS_DIR"
