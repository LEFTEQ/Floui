#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/release-common.sh"

CONFIG_FILE="$ROOT_DIR/config/release/release.env"
APP_PATH=""
WITH_DMG=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)
      CONFIG_FILE="$2"
      shift 2
      ;;
    --app)
      APP_PATH="$2"
      shift 2
      ;;
    --with-dmg)
      WITH_DMG=1
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

load_release_env "$CONFIG_FILE"

ensure_command ditto

if [[ -z "$APP_PATH" ]]; then
  APP_PATH="$(release_app_path "$(default_release_output_dir)")"
fi

if [[ ! -d "$APP_PATH" ]]; then
  echo "App bundle not found: $APP_PATH" >&2
  exit 1
fi

APP_DIR="$(dirname "$APP_PATH")"
APP_NAME="$(resolve_app_name)"
RELEASE_VERSION="$(resolve_release_version)"
ZIP_PATH="$APP_DIR/${APP_NAME}-${RELEASE_VERSION}.zip"

rm -f "$ZIP_PATH"
ditto -c -k --sequesterRsrc --keepParent "$APP_PATH" "$ZIP_PATH"
print_release_summary "$APP_PATH" "$ZIP_PATH"

if [[ "$WITH_DMG" == "1" ]]; then
  ensure_command hdiutil
  DMG_PATH="$APP_DIR/${APP_NAME}-${RELEASE_VERSION}.dmg"
  STAGING_DIR="$APP_DIR/.dmg-staging"
  rm -rf "$STAGING_DIR" "$DMG_PATH"
  mkdir -p "$STAGING_DIR"
  cp -R "$APP_PATH" "$STAGING_DIR/"
  ln -s /Applications "$STAGING_DIR/Applications"
  hdiutil create -volname "$APP_NAME" -srcfolder "$STAGING_DIR" -ov -format UDZO "$DMG_PATH"
  rm -rf "$STAGING_DIR"
  print_release_summary "$APP_PATH" "$DMG_PATH"
fi
